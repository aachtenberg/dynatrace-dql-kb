# Copy to .env and fill in. The .env file is gitignored — never commit real tokens.

# Dynatrace tenant URL (the Platform/apps URL, no trailing slash)
#   e.g. https://abc12345.apps.dynatrace.com
DT_ENVIRONMENT_URL=https://YOUR_ENV.apps.dynatrace.com

# Dynatrace API token (dt0c01...) with Grail read scopes:
#   storage:metrics:read, storage:entities:read, storage:logs:read,
#   storage:events:read, storage:bizevents:read, storage:spans:read,
#   storage:buckets:read
DT_API_TOKEN=dt0c01.XXXXXXXX

# ----- Optional: RAG pipeline LLM provider (see README) -----
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://192.168.0.150:11434
# OLLAMA_MODEL=qwen3.6:27b
